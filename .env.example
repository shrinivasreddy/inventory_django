# Copy to .env and fill in real values.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DJANGO_SECRET_KEY=change-this-to-a-random-string

# Leave false/unset for anything resembling production -- Django's debug
# mode shows a very detailed error page (including settings/environment
# values) to anyone who triggers an error. Only ever true on your own machine.
DJANGO_DEBUG=false

# Comma-separated. Django refuses to serve requests for a Host header not
# in this list -- add your server's actual hostname/IP once you know it.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,inventory.mycompany.local

# 0.0.0.0 = listen on all network interfaces (needed for your team to reach
# it). 127.0.0.1 = only reachable from this machine.
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_THREADS=32

# ---- Optional: only set these if you need something other than the defaults ----

# Where your team is located -- affects how timestamps display in the admin.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
DJANGO_TIME_ZONE=UTC

DJANGO_LANGUAGE_CODE=en-us

# Change from the default "admin/" if you want a less-guessable admin URL.
# Must end with a slash.
DJANGO_ADMIN_URL=admin/

# Custom path for the SQLite database file, if you want it somewhere other
# than the project folder (e.g. a separate drive for easier backups).
# DJANGO_DB_PATH=D:\InventoryData\db.sqlite3

# Only needed if you put this behind a reverse proxy on a specific HTTPS
# domain and see CSRF errors on the /admin/ login form. Comma-separated,
# must include the scheme, e.g.:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://inventory.mycompany.com

# Enable these together for an HTTPS production deployment. If TLS terminates
# at a trusted reverse proxy, also enable DJANGO_TRUST_PROXY_SSL_HEADER.
# Do not enable secure cookies while serving plain HTTP: browsers will not send
# them and users will be unable to remain logged in.
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_TRUST_PROXY_SSL_HEADER=true

# Enable HSTS only after HTTPS is confirmed working for the domain. Start with
# a short value, then increase to 31536000. HSTS is cached by browsers.
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_PRELOAD=false

# Password-reset email. The default console backend prints reset links in the
# server terminal for local testing. Configure SMTP in production.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=your-smtp-user
# DJANGO_EMAIL_HOST_PASSWORD=your-smtp-password
# DJANGO_EMAIL_USE_TLS=true
# DJANGO_EMAIL_USE_SSL=false
# DJANGO_DEFAULT_FROM_EMAIL=Inventory Web <no-reply@example.com>
# DJANGO_EMAIL_TIMEOUT=10
